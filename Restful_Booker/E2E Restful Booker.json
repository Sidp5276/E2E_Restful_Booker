    {
      "name": "Booking - CreateBooking",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Response has bookingid\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property(\"bookingid\");",
              "    pm.expect(jsonData.bookingid).to.be.a(\"number\");",
              "});",
              "",
              "pm.test(\"Response has booking object\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property(\"booking\");",
              "});",
              "",
              "pm.test(\"Booking firstname matches request\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.booking.firstname).to.eql(\"Jim\");",
              "});",
              "",
              "pm.test(\"Booking lastname matches request\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.booking.lastname).to.eql(\"Brown\");",
              "});",
              "",
              "pm.test(\"Booking totalprice matches request\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.booking.totalprice).to.eql(111);",
              "});",
              "",
              "pm.test(\"Booking depositpaid matches request\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.booking.depositpaid).to.eql(true);",
              "});",
              "",
              "pm.test(\"Booking additionalneeds matches request\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.booking.additionalneeds).to.eql(\"Breakfast\");",
              "});",
              "",
              "pm.test(\"Response time is less than 5000ms\", function () {",
              "    pm.expect(pm.response.responseTime).to.be.below(5000);",
              "});",
              "",
              "// Save bookingId to collection variable",
              "var jsonData = pm.response.json();",
              "if (jsonData.bookingid) {",
              "    pm.collectionVariables.set(\"bookingId\", jsonData.bookingid);",
              "    console.log(\"Booking ID saved: \" + jsonData.bookingid);",
              "}"
            ]
          }
        }
