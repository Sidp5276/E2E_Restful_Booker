              "var perfMetrics = JSON.parse(pm.collectionVariables.get(\"perfMetrics\") || '{\"totalRequests\":0,\"totalTime\":0,\"failures\":0,\"maxTime\":0,\"minTime\":999999}');",
              "",
              "perfMetrics.totalTime += responseTime;",
              "if (responseTime > perfMetrics.maxTime) perfMetrics.maxTime = responseTime;",
              "if (responseTime < perfMetrics.minTime) perfMetrics.minTime = responseTime;",
              "",
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "    if (pm.response.code !== 200) perfMetrics.failures++;",
              "});",
              "",
              "pm.test(\"Response time under 2000ms per request (performance threshold)\", function () {",
              "    pm.expect(responseTime).to.be.below(2000);",
              "    if (responseTime >= 2000) perfMetrics.failures++;",
              "});",
              "",
              "pm.test(\"Valid token returned under load\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property(\"token\");",
              "    pm.expect(jsonData.token).to.not.equal(\"Bad credentials\");",
              "});",
              "",
              "pm.test(\"Performance metrics tracked\", function () {",
              "    var avgTime = perfMetrics.totalRequests > 0 ? (perfMetrics.totalTime / perfMetrics.totalRequests).toFixed(2) : 0;",
              "    console.log(\"=== Performance Metrics ===\");",
              "    console.log(\"Total Requests: \" + perfMetrics.totalRequests);",
              "    console.log(\"Avg Response Time: \" + avgTime + \"ms\");",
              "    console.log(\"Max Response Time: \" + perfMetrics.maxTime + \"ms\");",
              "    console.log(\"Min Response Time: \" + perfMetrics.minTime + \"ms\");",
              "    console.log(\"Failures: \" + perfMetrics.failures);",
              "    pm.expect(perfMetrics.failures).to.equal(0);",
              "});",
              "",
              "pm.collectionVariables.set(\"perfMetrics\", JSON.stringify(perfMetrics));"
            ]
          }
        }
